# --- Legacy optional providers (no longer required) ---
FOOTBALL_DATA_ORG_TOKEN=
API_FOOTBALL_KEY=
THE_ODDS_API_KEY=
THESPORTSDB_KEY=3

# --- Zero-cost provider stack ---
ENABLE_SCRAPER_STACK=true
ENABLE_UNDERSTAT=true
ENABLE_FBREF=true
ENABLE_SOFASCORE=true
ENABLE_TRANSFERMARKT=true
ENABLE_ODDSPORTAL=true
ENABLE_CLUBELO=true
ENABLE_OPENFOOTBALL=true
ENABLE_OPEN_METEO=true

# --- App config ---
TRACKED_COMPETITIONS=PL,PD,SA,BL1,FL1,DED,PPL,ELC,TR1,BEL,SL,A1,GR1,SWS,DK1,SE1,NO1,PL1
LOOKAHEAD_DAYS=7
DB_PATH=./data/footy.duckdb
REQUEST_TIMEOUT_SECONDS=20
SCRAPER_CACHE_TTL_SECONDS=900
PRE_MATCH_REFRESH_MINUTES=15
ODDS_MOVEMENT_THRESHOLD=0.05

# --- LLM ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER_ORDER=groq,ollama

# --- Weather ---
OPEN_METEO_COMMERCIAL_USE=false
